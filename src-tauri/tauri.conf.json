{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aperture",
  "version": "0.1.0",
  "identifier": "dev.aperture.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aperture",
        "width": 1000,
        "height": 720,
        "resizable": true,
        "visible": true,
        "theme": "Dark",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
