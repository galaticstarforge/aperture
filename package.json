{
  "name": "aperture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Aperture — a GUI-native .mjs script runner (Phase 2: state, schema, reactivity)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:shim": "node --test runtime-shim/__tests__/*.test.mjs",
    "test:shim:watch": "node --test --watch runtime-shim/__tests__/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:shim"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.0",
    "@tauri-apps/api": "^2.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
